{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "PostgreSql": "",
    "Redis": "",
    "RabbitMq": "",
    "IdentityDb": "Data Source=aipm.identity.db"
  },
  "Security": {
    "ApiKey": ""
  },
  "OpenTelemetry": {
    "ServiceName": "aipm-host"
  },
  "Deployment": {
    "Profile": "saas"
  },
  "Platform": {
    "ServiceName": "aipm-host",
    "RequireTenantHeader": false,
    "AllowUnsignedPluginsDev": true
  },
  "AllowedHosts": "*"
}
